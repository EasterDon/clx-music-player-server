{
  "compilerOptions": {
    "target": "es2017",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src-dev",
    "outDir": "./src",
    "paths": {
      "#*": ["./src-dev/*"]
    },
    "types": ["node"]
  },
  "include": ["src-dev"],
  "exclude": ["node_modules", "src", "public"]
}
