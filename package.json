    "lint:fix": "eslint src-dev --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "imports": {
    "#*": "./src/*"
  },
  "dependencies": {
    "@fastify/postgres": "^6.0.2",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "tar": "^7.5.16"
  }
